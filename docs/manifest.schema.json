{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skills-migration/export-manifest.schema.json",
  "title": "Skills Migration Export Manifest",
  "type": "object",
  "required": [
    "export_version",
    "created_at",
    "source_os",
    "source_hostname",
    "detected_agents",
    "categories",
    "file_count",
    "total_size",
    "checksums",
    "files",
    "skipped_sensitive_files"
  ],
  "properties": {
    "export_version": { "const": "1.0.0" },
    "created_at": { "type": "string", "format": "date-time" },
    "source_os": { "type": "string" },
    "source_hostname": { "type": "string" },
    "detected_agents": {
      "type": "array",
      "items": { "enum": ["claude", "codex", "openclaw", "cursor", "opencode", "hermes", "gemini"] }
    },
    "categories": {
      "type": "array",
      "items": {
        "enum": ["skills", "agents", "commands", "prompts", "mcp_configs", "settings", "memories", "sessions", "secrets", "unknown"]
      }
    },
    "file_count": { "type": "integer", "minimum": 0 },
    "total_size": { "type": "integer", "minimum": 0 },
    "checksums": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "agent_name",
          "category",
          "original_path",
          "portable_target_path",
          "relative_path",
          "size",
          "checksum",
          "risk_level"
        ],
        "properties": {
          "id": { "type": "string" },
          "agent_name": { "enum": ["claude", "codex", "openclaw", "cursor", "opencode", "hermes", "gemini"] },
          "category": {
            "enum": ["skills", "agents", "commands", "prompts", "mcp_configs", "settings", "memories", "sessions", "secrets", "unknown"]
          },
          "original_path": { "type": "string" },
          "portable_target_path": { "type": "string" },
          "relative_path": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "risk_level": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "skipped_sensitive_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_name", "path", "category", "reason"],
        "properties": {
          "agent_name": { "type": "string" },
          "path": { "type": "string" },
          "category": { "type": "string" },
          "reason": { "type": "string" },
          "redacted_preview": { "type": "string" }
        }
      }
    }
  }
}
